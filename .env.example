# Copia este archivo: cp .env.example .env  y edita los valores.
# Las versiones de las imágenes Docker están fijadas en docker-compose.yml.

# --- Base de datos (PostgreSQL) ---
POSTGRES_PASSWORD=cambia_esta_contraseña
POSTGRES_USER=nextcloud
POSTGRES_DB=nextcloud

# Dominio(s) de confianza (separados por espacio si hay varios)
NEXTCLOUD_TRUSTED_DOMAINS=cloud.midominio.com

# Recomendado si usas proxy inverso HTTPS (Nginx Proxy Manager, Traefik, etc.)
OVERWRITEHOST=cloud.midominio.com
OVERWRITEPROTOCOL=https

HTTP_PORT=8080
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=16G
